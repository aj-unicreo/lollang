{
  "name": "lollang",
  "version": "0.1.0",
  "description": "A laughter-keyword language that transpiles to JavaScript. Every keyword is a laugh.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "lollang": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs/SPEC.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src test",
    "lint:fix": "biome check --write src test",
    "format": "biome format --write src test",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test",
    "prepublishOnly": "npm run check && npm run build"
  },
  "dependencies": {
    "acorn": "^8.14.0",
    "acorn-walk": "^8.3.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "lollang",
    "transpiler",
    "javascript",
    "obfuscator",
    "language",
    "esoteric",
    "joke",
    "laugh",
    "lol"
  ],
  "author": "aj <aj@unicreo.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aj-unicreo/lollang.git"
  },
  "bugs": {
    "url": "https://github.com/aj-unicreo/lollang/issues"
  },
  "homepage": "https://github.com/aj-unicreo/lollang#readme"
}
